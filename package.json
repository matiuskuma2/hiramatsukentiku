{
  "name": "hiramatsu-cost",
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=hiramatsu-cost-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name hiramatsu-cost",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply hiramatsu-cost-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply hiramatsu-cost-production",
    "db:seed": "wrangler d1 execute hiramatsu-cost-production --local --file=./seeds/seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute hiramatsu-cost-production --local",
    "db:console:prod": "wrangler d1 execute hiramatsu-cost-production",
    "spike:test": "node --experimental-vm-modules spike/run-spike.mjs",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true"
  },
  "dependencies": {
    "hono": "^4.12.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
